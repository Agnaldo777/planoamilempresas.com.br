# ============================================================================
# planoamilempresas.com.br - Variáveis de Ambiente
# ============================================================================
# Story 1.2 (AC5) — todas as 14 keys placeholders, valores reais aplicados em
# Stories 1.5 (analytics) e 4.3 (CRM). Copiar para `.env.local` (dev) e
# configurar via Vercel Dashboard em production / preview / development.
# ============================================================================

# ----------------------------------------------------------------------------
# Site (sempre exposto ao client)
# ----------------------------------------------------------------------------
# Domínio canônico do site (sem barra final). Trocar por preview/staging URL
# em ambientes não-produção se necessário.
NEXT_PUBLIC_SITE_URL=https://planoamilempresas.com.br

# WhatsApp do corretor BeneficioRH (Agnaldo Silva). Formato E.164 sem '+'.
NEXT_PUBLIC_WHATSAPP_NUMBER=5511926510515

# ----------------------------------------------------------------------------
# Analytics & Observability (Story 1.5)
# ----------------------------------------------------------------------------
# Google Analytics 4 — Property ID (G-XXXXXXXXXX). Obter em
# https://analytics.google.com/ → Admin → Data Streams → Web.
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Search Console — string de verificação (meta tag content).
# Obter em https://search.google.com/search-console → propriedade → HTML tag.
GSC_VERIFICATION=replace_with_gsc_token

# Sentry — DSN do projeto. Obter em https://sentry.io → Project → Settings → Client Keys (DSN).
SENTRY_DSN=https://example@o0.ingest.sentry.io/0

# Microsoft Clarity — Project ID (10 chars). Obter em https://clarity.microsoft.com/.
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ----------------------------------------------------------------------------
# Upstash Redis (Story 1.2 AC10) — rate-limiting + cache CNPJ
# ----------------------------------------------------------------------------
# Free tier MVP. Região recomendada: sa-east-1 (São Paulo).
# Obter em https://console.upstash.com/ → Database → REST API.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_rest_token

# ----------------------------------------------------------------------------
# CRM (Story 4.3) — adapter pattern (ADR-002)
# ----------------------------------------------------------------------------
# Provider canônico para Wave 1 (Clint — vertical brasileiro corretoras de seguros).
# Fallbacks suportados via adapter: rdstation | hubspot | pipedrive.
CRM_PROVIDER=clint

# API Key do provider escolhido. Sensitive — Server-only.
CRM_API_KEY=replace_with_crm_api_key

# ----------------------------------------------------------------------------
# Receita / CNPJ enrichment (opcional)
# ----------------------------------------------------------------------------
# Fallback automático: BrasilAPI pública (sem chave) caso não preenchido.
RECEITA_API_KEY=

# ----------------------------------------------------------------------------
# Cloudflare Turnstile (anti-bot CAPTCHA — formulários Story 4.x)
# ----------------------------------------------------------------------------
# Obter em https://dash.cloudflare.com/?to=/:account/turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxx_secret

# ----------------------------------------------------------------------------
# Sanity CMS (ADR-001)
# ----------------------------------------------------------------------------
# Obter em https://www.sanity.io/manage → Project → API.
SANITY_PROJECT_ID=replace_with_sanity_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Read token Sanity (server-only). Apenas para previews e queries privadas.
SANITY_API_READ_TOKEN=replace_with_sanity_read_token

# Aliases NEXT_PUBLIC_* (legado) — manter sincronizados com os acima até
# refactor de lib/sanity/client.ts (Story 3.x).
NEXT_PUBLIC_SANITY_PROJECT_ID=replace_with_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Webhook secret para revalidação on-demand.
SANITY_REVALIDATE_SECRET=replace_with_revalidate_secret

# ----------------------------------------------------------------------------
# Cloudflare Workers (ADR-011 — plataforma de deploy)
# ----------------------------------------------------------------------------
# Estas vars são auto-injetadas pelo runtime Cloudflare em produção e NÃO
# precisam ser definidas em Workers Dashboard. Listadas aqui para dev local
# e referência (CF_VERSION_METADATA é JSON `{id,tag}`).
#
# CF_VERSION_METADATA={"id":"abcdef1...","tag":"v1.0.0"}
# CF_ENV=production|preview|development

# Build-time SHA fornecido pelo GitHub Actions:
# GITHUB_SHA=auto-injected-by-actions

# ============================================================================
# NUNCA commitar valores reais. Este arquivo é template.
# Stakeholder configurar valores via Cloudflare Dashboard ou
# `wrangler secret put <KEY>` (3 environments: production, preview, dev).
# Ver docs/devops/env-vars.md para o mapping completo.
# ============================================================================
