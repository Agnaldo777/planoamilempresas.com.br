  "scripts": {
    "dev": "next dev",
    "build:search-index": "node scripts/build-minisearch-index.mjs",
    "prebuild": "node scripts/build-minisearch-index.mjs",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && wrangler dev",
    "deploy:cf": "opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "audit:rede": "node scripts/audit-network-coverage.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sanity/image-url": "^2.0.3",
    "@sanity/vision": "^5.17.1",
    "lucide-react": "^0.577.0",
    "minisearch": "^7.2.0",
    "next": "^16.1.7",
    "next-sanity": "^12.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sanity": "^5.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.2.1",
